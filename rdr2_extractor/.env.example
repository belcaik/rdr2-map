# RDR2 Extractor Environment Configuration
# Copy this file to .env and customize as needed

# Target website
RDR2_TARGET_URL=https://rdr2map.com

# Browser settings
RDR2_HEADLESS=true
RDR2_STEALTH_MODE=true

# Download settings
RDR2_RATE_LIMIT=2.0
RDR2_MAX_CONCURRENT=3
RDR2_MAX_TILES=1000

# Output directory
RDR2_OUTPUT_DIR=data

# Logging
RDR2_LOG_LEVEL=INFO
RDR2_LOG_FILE=rdr2_extractor.log

# Optional: Custom user agent
# RDR2_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Optional: Proxy settings
# RDR2_PROXY_HOST=
# RDR2_PROXY_PORT=
# RDR2_PROXY_USER=
# RDR2_PROXY_PASS=